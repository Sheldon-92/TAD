{
  "permissions": {
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .tad/hooks/startup-health.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .tad/hooks/post-write-sync.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
