// Multi-Tenant SaaS Billing System — Prisma Schema
// Strategy: Shared DB with tenant_id column + application-level filtering
// [ASSUMPTION] PostgreSQL as primary database

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ═══════════════════════════════════════
// Enums
// ═══════════════════════════════════════

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  BILLING_ADMIN
  MEMBER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum InvoiceLineItemType {
  SUBSCRIPTION
  PRORATION_CREDIT
  PRORATION_CHARGE
  OVERAGE
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
}

// ═══════════════════════════════════════
// Core Models
// ═══════════════════════════════════════

/// Tenant (organization) — top-level multi-tenancy boundary
model Tenant {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  billingEmail     String
  stripeCustomerId String?   @unique

  // Soft delete
  deletedAt        DateTime?

  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  users         User[]
  subscriptions Subscription[]
  invoices      Invoice[]
  usageRecords  UsageRecord[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]

  @@index([slug])
  @@index([deletedAt])
}

/// User within a tenant
model User {
  id           String    @id @default(cuid())
  email        String
  name         String
  passwordHash String
  role         UserRole  @default(MEMBER)

  // Tenant scope
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  // Soft delete
  deletedAt    DateTime?

  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  auditLogs    AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([deletedAt])
}

/// API Key for server-to-server auth (usage recording, etc.)
model ApiKey {
  id          String   @id @default(cuid())
  keyHash     String   @unique // SHA-256 hash of the actual key
  name        String   // Human-readable label
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([keyHash])
}

// ═══════════════════════════════════════
// Plan & Feature Models
// ═══════════════════════════════════════

/// Subscription plan definition (platform-wide, not tenant-scoped)
model Plan {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  priceMonthly  Int      // Price in cents
  priceYearly   Int?     // Annual price in cents (discounted)
  currency      String   @default("usd")
  trialDays     Int      @default(0)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  stripePriceId String?  @unique

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  features      PlanFeature[]
  subscriptions Subscription[]

  @@index([isActive])
  @@index([slug])
}

/// Feature limits within a plan (e.g., API calls, storage, seats)
model PlanFeature {
  id           String @id @default(cuid())
  planId       String
  plan         Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  name         String // e.g., "api_calls", "storage", "team_members"
  limit        Int    // -1 = unlimited
  unit         String // e.g., "calls/month", "GB", "seats"
  overagePrice Int?   // Price per unit over limit, in cents

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  subscriptionItems SubscriptionItem[]

  @@unique([planId, name])
  @@index([planId])
}

// ═══════════════════════════════════════
// Subscription Models
// ═══════════════════════════════════════

/// Subscription — links a tenant to a plan
model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  planId               String
  plan                 Plan               @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  canceledAt           DateTime?
  cancelReason         String?
  trialEnd             DateTime?
  gracePeriodEnd       DateTime?          // 7 days after cancellation
  stripeSubscriptionId String?            @unique

  // Optimistic locking for concurrent upgrade protection
  version              Int                @default(1)

  // Timestamps
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relations
  items                SubscriptionItem[]
  invoices             Invoice[]
  usageRecords         UsageRecord[]

  @@index([tenantId])
  @@index([status])
  @@index([planId])
  @@index([currentPeriodEnd])
}

/// Subscription item — links subscription to specific plan features
model SubscriptionItem {
  id              String      @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  planFeatureId   String
  planFeature     PlanFeature  @relation(fields: [planFeatureId], references: [id])
  quantity        Int          @default(1) // For seat-based features

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([subscriptionId, planFeatureId])
  @@index([subscriptionId])
}

// ═══════════════════════════════════════
// Invoice & Payment Models
// ═══════════════════════════════════════

/// Invoice — billing document for a subscription period
model Invoice {
  id               String        @id @default(cuid())
  subscriptionId   String
  subscription     Subscription  @relation(fields: [subscriptionId], references: [id])
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  status           InvoiceStatus @default(DRAFT)
  amountDue        Int           // Total amount in cents
  amountPaid       Int           @default(0)
  currency         String        @default("usd")
  dueDate          DateTime
  paidAt           DateTime?
  stripeInvoiceId  String?       @unique

  // Timestamps
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  lineItems        InvoiceLineItem[]
  payments         Payment[]

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

/// Invoice line item — breakdown of charges
model InvoiceLineItem {
  id          String              @id @default(cuid())
  invoiceId   String
  invoice     Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int                 @default(1)
  unitPrice   Int                // Price per unit in cents
  amount      Int                // Total = quantity × unitPrice
  type        InvoiceLineItemType

  createdAt   DateTime           @default(now())

  @@index([invoiceId])
}

/// Payment attempt for an invoice
model Payment {
  id                     String        @id @default(cuid())
  invoiceId              String
  invoice                Invoice       @relation(fields: [invoiceId], references: [id])
  amount                 Int           // Amount in cents
  status                 PaymentStatus @default(PENDING)
  stripePaymentIntentId  String?       @unique
  failureCode            String?       // Stripe error code (e.g., "card_declined")
  failureMessage         String?       // Human-readable failure message
  attemptNumber          Int           @default(1)

  // Timestamps
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([invoiceId])
  @@index([status])
  @@index([stripePaymentIntentId])
}

// ═══════════════════════════════════════
// Usage Tracking
// ═══════════════════════════════════════

/// Usage record — tracks API calls, storage, etc.
model UsageRecord {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  featureName     String       // e.g., "api_calls", "storage"
  quantity        Int
  transactionId   String       @unique // Client-provided for idempotency
  timestamp       DateTime     // When the usage occurred

  createdAt       DateTime     @default(now())

  @@index([tenantId, featureName, timestamp])
  @@index([subscriptionId, featureName, timestamp])
  @@index([transactionId])
}

// ═══════════════════════════════════════
// Webhook & Audit
// ═══════════════════════════════════════

/// Stripe webhook event log — for idempotency and debugging
model WebhookEvent {
  id              String             @id @default(cuid())
  stripeEventId   String             @unique // Stripe event ID for dedup
  eventType       String             // e.g., "invoice.payment_failed"
  status          WebhookEventStatus @default(RECEIVED)
  payload         Json               // Raw Stripe event payload
  processedAt     DateTime?
  errorMessage    String?
  retryCount      Int                @default(0)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([stripeEventId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
}

/// Audit log — tracks all changes for compliance
model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String?
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  action      AuditAction
  entityType  String      // e.g., "Subscription", "Invoice"
  entityId    String
  before      Json?       // State before change
  after       Json?       // State after change
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime    @default(now())

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
