    "sm": "10pt",
    "md": "13pt",
    "lg": "20pt",
    "xl": "44pt",
    "description": "iOS HIG standard corner radii. xl for pill shapes."
  },
  "touchTarget": {
    "minimum": "44pt",
    "recommended": "48pt",
    "platform": "iOS",
    "source": "Apple HIG"
  },
  "layout": {
    "screenWidth": "390pt",
    "screenHeight": "844pt",
    "statusBarHeight_dynamicIsland": "59pt",
    "navBarHeight": "44pt",
    "tabBarHeight": "83pt",
    "homeIndicator": "34pt",
    "contentInset": "16pt",
    "gridUnit": "8pt"
  },
  "icons": {
    "system": "SF Symbols",
    "rendering_mode": "hierarchical",
    "weight": "regular",
    "app_specific": {
      "scan_tab": "camera.viewfinder",
      "history_tab": "clock.arrow.circlepath",
      "favorites_tab": "heart.fill",
      "settings_tab": "gearshape",
      "flash": "bolt.fill",
      "camera_switch": "arrow.triangle.2.circlepath.camera",
      "filter": "line.3.horizontal.decrease",
      "share": "square.and.arrow.up",
      "allergen_warning": "exclamationmark.triangle.fill",
      "safe_check": "checkmark.circle.fill",
      "ai_sparkle": "sparkles",
      "back": "chevron.left",
      "chevron_right": "chevron.right",
      "close": "xmark",
      "search": "magnifyingglass",
      "delete": "trash",
      "rescan": "arrow.clockwise"
    }
  },
  "animation": {
    "micro_interaction": "150-300ms",
    "page_transition": "300-350ms",
    "spring": {
      "response": 0.5,
      "dampingFraction": 0.8
    },
    "exit_multiplier": "0.6-0.7x of enter"
  },
  "dark_mode": {
    "strategy": "iOS Elevated system — NOT simple color inversion",
    "background_levels": {
      "base": "#000000",
      "elevated_1": "#1C1C1E",
      "elevated_2": "#2C2C2E",
      "elevated_3": "#3A3A3C"
    },
    "text_on_dark": {
      "primary": "#FFFFFF",
      "secondary": "rgba(235, 235, 245, 0.6)",
      "tertiary": "rgba(235, 235, 245, 0.3)"
    },
    "separator": "#38383A",
    "notes": "Cards in dark mode use elevated_2 to create depth. Tab bar and nav bar use system blur material."
  }
}
