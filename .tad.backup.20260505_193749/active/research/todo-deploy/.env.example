# ══════════════════════════════════════════════════════════════
# Todo App — Environment Variables
# Copy to .env.local and fill in real values
# ══════════════════════════════════════════════════════════════

# ── L1 Critical (CI/CD injection only, NEVER in .env files) ──
# These must be set in Vercel Dashboard > Settings > Environment Variables
# DATABASE_URL=postgresql://user:password@host:5432/todoapp    # type: url, REQUIRED
# JWT_SECRET=                                                   # type: string (min 32 chars), REQUIRED
# ENCRYPTION_KEY=                                               # type: string (32 bytes hex), REQUIRED

# ── L2 Sensitive (Platform env vars) ──
# Set in Vercel Dashboard or GitHub Secrets
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0      # type: url, REQUIRED for error tracking
SENTRY_AUTH_TOKEN=                                               # type: string, REQUIRED for source maps upload
SMTP_HOST=smtp.example.com                                       # type: string, optional (email notifications)
SMTP_PORT=587                                                    # type: number, optional
SMTP_USER=                                                       # type: string, optional
SMTP_PASSWORD=                                                   # type: string, optional

# ── L3 Config (Safe for .env files) ──
DATABASE_URL=file:./dev.db                                       # type: url, REQUIRED — SQLite for dev, PostgreSQL for prod
NODE_ENV=development                                             # type: enum(development|test|staging|production), REQUIRED
APP_URL=http://localhost:3000                                    # type: url, REQUIRED
API_BASE_URL=http://localhost:3000/api                           # type: url, REQUIRED

# Auth config
JWT_SECRET=dev-secret-change-in-production-min-32-chars-long!!   # type: string, REQUIRED — OVERRIDE in prod via L1!
JWT_EXPIRY=7d                                                    # type: string (zeit/ms format), optional, default: 7d

# Feature flags
ENABLE_REGISTRATION=true                                         # type: boolean, optional, default: true
ENABLE_EMAIL_NOTIFICATIONS=false                                 # type: boolean, optional, default: false
MAX_TODOS_PER_USER=100                                           # type: number, optional, default: 100

# ── L4 Public (Safe for client-side, code constants OK) ──
NEXT_PUBLIC_APP_NAME=TodoApp                                     # type: string, REQUIRED
NEXT_PUBLIC_APP_VERSION=1.0.0                                    # type: string, REQUIRED
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0  # type: url, optional (client-side error tracking)
NEXT_PUBLIC_API_URL=/api                                         # type: string, REQUIRED

# ══════════════════════════════════════════════════════════════
# Security Notes:
# - NEXT_PUBLIC_* variables are exposed to the browser!
# - Never put L1/L2 secrets in NEXT_PUBLIC_* variables
# - L1 secrets: Set ONLY in Vercel Dashboard / GitHub Secrets
# - This file (.env.example) is safe to commit to git
# - .env, .env.local, .env.*.local must be in .gitignore
# ══════════════════════════════════════════════════════════════
