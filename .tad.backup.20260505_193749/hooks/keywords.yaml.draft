# Generated by .tad/hooks/generate-keywords.sh on 2026-04-07
# MODE: full
# ENGLISH HEURISTIC ONLY. Chinese keywords MUST be hand-added after generation.
# Deduplication audit required before use:
#   - Any keyword in > 2 packs → remove or specialize
#   - Each pack must have >= 3 unique anchors (zero cross-pack)
#   - Each pack must have >= 3 Chinese AND >= 3 English after curation
# Banned high-collision words: build, code, test, project, system, api, design, tool, file, data

whitelist:
  - "yes"
  - "no"
  - "ok"
  - "y"
  - "n"
  - "继续"
  - "嗯"
  - "明白"
  - "收到"
  - "好的"

packs:
  - name: ai-agent-architecture
    file: .tad/domains/ai-agent-architecture.yaml
    # description: AI Agent 架构设计：从概念到可实现的蓝图。产出物是设计文档 + 架构图，不是代码。框架无关：适用于 Claude Code / OpenClaw / LangChain / 自建。核心价值：防止 agent 在生产中失败（幻觉、无限
    # NOTE: English tokens only. Chinese keywords MUST be hand-added.
    keywords:
      - "behavior"
      - "budget"
      - "claude"
      - "context"
      - "enforcement"
      - "improvement"
      - "langchain"
      - "memory"
      - "multi"
      - "openclaw"
      - "production"
      - "prompt"
      - "readiness"
      - "reliability"
      - "role"
      - "safety"
      - "schema"
      - "self"
    threshold: 1   # adjust to 2 if pack has >= 8 keywords

  - name: ai-evaluation
    file: .tad/domains/ai-evaluation.yaml
    # description: AI 评估：Agent 行为的基准测试、回归检测、对抗性安全验证、自动化评估管线。核心价值：用工具产出评估报告和测试脚本，不是写建议。
    # NOTE: English tokens only. Chinese keywords MUST be hand-added.
    keywords:
      - "adversarial"
      - "agent"
