# OS Files
.DS_Store

# BMAD Files (Not part of TAD)
.bmad-core/
.bmad/
.claude/commands/BMad/

# Local settings
.claude/settings.local.json

# Local skills (*save-skill output — project-local, never distributed)
.claude/skills/local/
# Mirror rule: parity --fix rsyncs .claude/skills → .agents/skills wholesale and can
# re-copy local/ into the tracked .agents tree — never commit it (public repo)
.agents/skills/local/

# Claude Code local session/memory + sub-agent worktree artifacts (not source)
.claude/projects/
.claude/worktrees/

# Timestamped backup snapshots (local only — not source)
.tad.backup.*/

# Dependencies
node_modules/

# Logs and temp files
*.log
*.tmp
*.bak

# TAD Framework - 默认全部纳入版本控制，运行时快照除外
.tad/active/session-state.md

# TAD Codex Adapter - portable-extract.sh output (generated, not committed)
codex-tad-bundle/

# TAD v1.5+ Work Directory
# Temporary work files (optional to exclude)
tad-work/working/*
!tad-work/working/.gitkeep

# Session context (optional - uncomment if you don't want to version control)
# tad-work/context/*
# !tad-work/context/.gitkeep

# Everything else in tad-work/ SHOULD be committed (handoffs, evidence, learnings)

# Research Methodology Capability Pack session data
.research/
.product-thinking/

# Reading Companion runtime workspaces (HTML is a regenerable view; truth = sidecar)
.reading/

__pycache__/
*.pyc

# TAD memory capture layer — sensitive memories never committed (public repo; SEC P0-1)
# Per-file entries from .tad/evidence/memory-migration-sensitivity-report.md (Gate 4 reviewed)
.tad/memory/user_*
.tad/memory/MEMORY.md
.tad/memory/feedback_share-mode-and-deflation.md
.tad/memory/project_co-thinking-workshop-seed.md
.tad/memory/project_tad-evolution-directions.md
.tad/memory/project_tad-universal-method.md
.tad/memory/reference_claude-code-source.md

# PreCompact mechanical session snapshots (transient hook output — CLAUDE.md §4.5 Layer 0; not source)
.tad/active/precompact/
# Raw stdin tee from real compacts (live session metadata — impl-review P2-2)
.tad/evidence/hooks/precompact-snapshot/last-stdin.json
